#!/usr/bin/env bash
# Pre-commit lint gate. Source of truth is this file; .git/hooks/pre-commit is
# a symlink to it — run: bash scripts/install-hooks.sh
# Lints staged files only: ESLint on .ts/.tsx, stylelint on .css (nightfall-src).
# Blocks on errors; warnings print but pass.
set -e

cd "$(git rev-parse --show-toplevel)"

mapfile -t TS_FILES < <(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^nightfall-src/.*\.(ts|tsx)$' \
    | grep -v node_modules \
    | sed 's|^nightfall-src/||' || true
)
if [ "${#TS_FILES[@]}" -gt 0 ]; then
  if ! (cd nightfall-src && npx eslint "${TS_FILES[@]}"); then
    echo ""
    echo "ESLint errors found — commit blocked. Fix before committing."
    exit 1
  fi
fi

mapfile -t CSS_FILES < <(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^nightfall-src/.*\.css$' \
    | grep -v node_modules \
    | sed 's|^nightfall-src/||' || true
)
if [ "${#CSS_FILES[@]}" -gt 0 ]; then
  if ! (cd nightfall-src && npx stylelint "${CSS_FILES[@]}"); then
    echo ""
    echo "stylelint errors found — commit blocked. Fix before committing."
    exit 1
  fi
fi

exit 0
